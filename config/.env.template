# ContentEngine Environment Configuration
# Copy this file to .env and fill in your API keys
# NEVER commit .env to git

# ── LLM ──────────────────────────────────────────────────────
# Phase 1 + Phase 2: script analysis and generation
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Phase 1 only (Whisper API transcription)
OPENAI_API_KEY=your_openai_api_key_here

# ── Voice (Phase 2 — voice clone in progress) ────────────────
# When ELEVENLABS_AMANDA_VOICE_ID is set, real TTS activates automatically.
# Leave blank to use silent stub audio — pipeline runs end-to-end without it.
ELEVENLABS_API_KEY=
ELEVENLABS_AMANDA_VOICE_ID=

# ── B-Roll (Phase 2) ─────────────────────────────────────────
PEXELS_API_KEY=
PEXELS_API_KEY_2=
PIXABAY_API_KEY=

# ── Whisper (Phase 2 — local transcription) ──────────────────
WHISPER_MODEL=base
